# SQL Query Agent Environment Variables
# Copy this file to .env and configure keys

# FastAPI server settings
PORT=8000

# AI Models Integration API Keys (Configure at least one to enable full AI agent functionality)
# If none are provided, the backend falls back to standard Demo/Mock Mode.

# Gemini API Key (Recommended)
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Alternative)
# Obtain from OpenAI Dashboard: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
